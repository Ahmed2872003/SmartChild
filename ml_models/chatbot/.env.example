# SmartChild Chatbot — Environment Variables
# Copy this file to .env and fill in your values

# ── Model ────────────────────────────────────────────────────────────────────
# Path to your fine-tuned LoRA adapter (output from Colab notebook)
MODEL_PATH=./model/weights

# Base model on HuggingFace (do NOT change unless you fine-tuned a different model)
BASE_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# ── Inference ────────────────────────────────────────────────────────────────
MAX_NEW_TOKENS=150
TEMPERATURE=0.7

# Use 4-bit quantization — set to false on CPU-only machines
USE_4BIT=true

# auto = use GPU if available, else CPU
DEVICE=auto

# ── Server ───────────────────────────────────────────────────────────────────
PORT=5001
DEBUG=false
